    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <LangVersion>latest</LangVersion>
    <AssemblyName>BattleTechTrainer</AssemblyName>
    <RootNamespace>BattleTech1Trainer</RootNamespace>
