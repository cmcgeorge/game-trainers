<Window x:Class="DarklandsTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Darklands — Trainer" Height="720" Width="900"
        Icon="Assets/app.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#EEE" Padding="6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Process:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="300" ItemsSource="{Binding Processes}" DisplayMemberPath="Display"
                          SelectedItem="{Binding SelectedProcess}"/>
                <Button Content="Refresh" Command="{Binding RefreshProcessesCommand}"/>
                <Button Content="Attach" Command="{Binding AttachCommand}"/>
                <Button Content="Detach" Command="{Binding DetachCommand}"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#EEE" Padding="6">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
        </Border>

        <TabControl Margin="6">
            <!-- Value Scanner -->
            <TabItem Header="Value Scanner">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F6F6F6" Padding="6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Type:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <ComboBox Width="80" ItemsSource="{Binding Widths}"
                                          SelectedItem="{Binding SelectedWidth}"
                                          IsEnabled="{Binding NotScanning}"
                                          ToolTip="Byte, 16-bit or 32-bit value. Changing this starts a new scan."/>
                                <TextBlock Text="Value:" VerticalAlignment="Center" Margin="10,0,4,0"/>
                                <TextBox Width="120" Text="{Binding ScanText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Decimal (30) or hex (0x1E). Leave blank for an unknown-value first scan."/>
                                <Button Content="First Scan" Command="{Binding FirstScanCommand}"/>
                                <Button Content="New Scan" Command="{Binding NewScanCommand}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Guides:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Button Content="Endurance" Command="{Binding EnduranceGuideCommand}"
                                        ToolTip="Step-by-step to pin a character's current Endurance (Byte)."/>
                                <Button Content="Strength" Command="{Binding StrengthGuideCommand}"
                                        ToolTip="Step-by-step to pin a character's Strength (Byte)."/>
                                <Button Content="Skill" Command="{Binding SkillGuideCommand}"
                                        ToolTip="Step-by-step to pin a skill level (Byte)."/>
                                <Button Content="Fame" Command="{Binding FameGuideCommand}"
                                        ToolTip="Step-by-step to pin the party Fame (Int16)."/>
                                <Button Content="Florins" Command="{Binding MoneyGuideCommand}"
                                        ToolTip="Step-by-step to pin the party's Florins (Int16)."/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Narrow:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Button Content="Exact" Command="{Binding NextScanCommand}" CommandParameter="Exact"/>
                                <Button Content="Increased" Command="{Binding NextScanCommand}" CommandParameter="Increased"/>
                                <Button Content="Decreased" Command="{Binding NextScanCommand}" CommandParameter="Decreased"/>
                                <Button Content="Changed" Command="{Binding NextScanCommand}" CommandParameter="Changed"/>
                                <Button Content="Unchanged" Command="{Binding NextScanCommand}" CommandParameter="Unchanged"/>
                                <TextBlock Text="{Binding MatchCount}" VerticalAlignment="Center" Margin="12,0,0,0"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border DockPanel.Dock="Bottom" Background="#F6F6F6" Padding="6">
                        <Button Content="Pin selected →" Command="{Binding PinCommand}" HorizontalAlignment="Left"
                                ToolTip="Add the selected candidate to the Freezes tab to edit or freeze it."/>
                    </Border>
                    <DataGrid ItemsSource="{Binding Results}" SelectedItem="{Binding SelectedResult}"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="True" HeadersVisibility="Column" Margin="0,6,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Address" Binding="{Binding AddressHex}" Width="220"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Freezes -->
            <TabItem Header="Freezes">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F6F6F6" Padding="6">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Freeze all" Command="{Binding FreezeAllCommand}"/>
                            <Button Content="Unfreeze all" Command="{Binding FreezeNoneCommand}"/>
                            <Button Content="Remove selected" Command="{Binding RemoveFrozenCommand}"/>
                            <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555"
                                       Text="Edit Target to poke a value; tick Freeze to re-write it every ~200 ms."/>
                        </StackPanel>
                    </Border>
                    <DataGrid ItemsSource="{Binding Frozen}" SelectedItem="{Binding SelectedFrozen}"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" Margin="0,6,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Label" Binding="{Binding Label}" IsReadOnly="True" Width="110"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding AddressHex}" IsReadOnly="True" Width="180"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding WidthLabel}" IsReadOnly="True" Width="60"/>
                            <DataGridTextColumn Header="Live" Binding="{Binding Live}" IsReadOnly="True" Width="90"/>
                            <DataGridTextColumn Header="Target"
                                                Binding="{Binding Target, UpdateSourceTrigger=LostFocus}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Freeze" Binding="{Binding Frozen}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Attributes -->
            <TabItem Header="Attributes">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F6F6F6" Padding="6">
                        <TextBlock TextWrapping="Wrap" Foreground="#555"
                                   Text="The six primary attributes are stored as single bytes (a current block and an identical max block); Divine Favor is party-wide. Use the Endurance / Strength / Skill guides to pin one."/>
                    </Border>
                    <DataGrid ItemsSource="{Binding Attributes}" AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" IsReadOnly="True" HeadersVisibility="Column" Margin="0,6,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                            <DataGridTextColumn Header="Attribute" Binding="{Binding Name}" Width="140"/>
                            <DataGridTextColumn Header="Governs" Binding="{Binding Governs}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Skills -->
            <TabItem Header="Skills">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F6F6F6" Padding="6">
                        <TextBlock TextWrapping="Wrap" Foreground="#555"
                                   Text="Each skill is stored as a single byte. The byte→skill mapping inside the save is still tentative, so pin a skill by value scan (Skill guide) rather than a fixed offset."/>
                    </Border>
                    <DataGrid ItemsSource="{Binding Skills}" AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" IsReadOnly="True" HeadersVisibility="Column" Margin="0,6,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                            <DataGridTextColumn Header="Skill" Binding="{Binding Name}" Width="140"/>
                            <DataGridTextColumn Header="Short" Binding="{Binding ShortName}" Width="110"/>
                            <DataGridTextColumn Header="Governs" Binding="{Binding Governs}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Reference -->
            <TabItem Header="Reference">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F6F6F6" Padding="6">
                        <TextBlock TextWrapping="Wrap" Foreground="#555"
                                   Text="Currency: 1 Florin = 20 Groschen = 240 Pfennig. The three coins are tracked separately in RAM — scan each on its own. Party Fame climbs the ladder below."/>
                    </Border>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <DataGrid Grid.Column="0" ItemsSource="{Binding Currency}" AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                  HeadersVisibility="Column" Margin="0,0,3,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Coin" Binding="{Binding Name}" Width="90"/>
                                <DataGridTextColumn Header="Abbr" Binding="{Binding Abbreviation}" Width="50"/>
                                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <DataGrid Grid.Column="1" ItemsSource="{Binding FameTiers}" AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                  HeadersVisibility="Column" Margin="3,0,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Fame tier (low → high)" Binding="{Binding}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
