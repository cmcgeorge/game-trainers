<Window x:Class="ThePerfectGeneral2Trainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="The Perfect General II Trainer" Height="700" Width="880"
        Icon="Assets/app.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#EEE" Padding="6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Process:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="300" ItemsSource="{Binding Processes}" DisplayMemberPath="Display"
                          SelectedItem="{Binding SelectedProcess}"/>
                <Button Content="Refresh" Command="{Binding RefreshProcessesCommand}"/>
                <Button Content="Attach" Command="{Binding AttachCommand}"/>
                <Button Content="Detach" Command="{Binding DetachCommand}"/>
                <Button Content="Auto-Locate" Command="{Binding AutoLocateCommand}"
                        ToolTip="Scan for the game's purchase state (Buy Points + unit counts) automatically — no manual searching needed."/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#EEE" Padding="6">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
        </Border>

        <TabControl Margin="6">
            <!-- Purchase (auto-located) -->
            <TabItem Header="Purchase">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F6F6F6" Padding="6">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Auto-Locate" Command="{Binding AutoLocateCommand}"
                                    ToolTip="Find the game's purchase state by scanning for the D:\ICONS\MSGR.DAT anchor string."/>
                            <Button Content="Freeze all" Command="{Binding FreezeAllPurchaseCommand}"/>
                            <Button Content="Unfreeze all" Command="{Binding UnfreezeAllPurchaseCommand}"/>
                            <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555"
                                       Text="On the purchase screen, click Auto-Locate to find Buy Points and unit counts. Edit Target to poke a value; tick Freeze to hold it."/>
                        </StackPanel>
                    </Border>
                    <DataGrid ItemsSource="{Binding PurchaseItems}"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" Margin="0,6,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item" Binding="{Binding Label}" IsReadOnly="True" Width="180"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding AddressHex}" IsReadOnly="True" Width="160"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding WidthLabel}" IsReadOnly="True" Width="55"/>
                            <DataGridTextColumn Header="Live" Binding="{Binding Live}" IsReadOnly="True" Width="70"/>
                            <DataGridTextColumn Header="Target"
                                                Binding="{Binding Target, UpdateSourceTrigger=LostFocus}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Freeze" Binding="{Binding Frozen}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Value Scanner -->
            <TabItem Header="Value Scanner">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F6F6F6" Padding="6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Type:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <ComboBox Width="80" ItemsSource="{Binding Widths}"
                                          SelectedItem="{Binding SelectedWidth}"
                                          IsEnabled="{Binding NotScanning}"
                                          ToolTip="Byte, 16-bit or 32-bit value. Changing this starts a new scan."/>
                                <TextBlock Text="Value:" VerticalAlignment="Center" Margin="10,0,4,0"/>
                                <TextBox Width="120" Text="{Binding ScanText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Decimal (39) or hex (0x27). Leave blank for an unknown-value first scan."/>
                                <Button Content="First Scan" Command="{Binding FirstScanCommand}"/>
                                <Button Content="New Scan" Command="{Binding NewScanCommand}"/>
                                <Button Content="Buy Points guide" Command="{Binding BuyPointsGuideCommand}"
                                        ToolTip="Step-by-step to pin Buy Points Remaining on the purchase screen."/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Narrow:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Button Content="Exact" Command="{Binding NextScanCommand}" CommandParameter="Exact"/>
                                <Button Content="Increased" Command="{Binding NextScanCommand}" CommandParameter="Increased"/>
                                <Button Content="Decreased" Command="{Binding NextScanCommand}" CommandParameter="Decreased"/>
                                <Button Content="Changed" Command="{Binding NextScanCommand}" CommandParameter="Changed"/>
                                <Button Content="Unchanged" Command="{Binding NextScanCommand}" CommandParameter="Unchanged"/>
                                <TextBlock Text="{Binding MatchCount}" VerticalAlignment="Center" Margin="12,0,0,0"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border DockPanel.Dock="Bottom" Background="#F6F6F6" Padding="6">
                        <Button Content="Pin selected →" Command="{Binding PinCommand}" HorizontalAlignment="Left"
                                ToolTip="Add the selected candidate to the Freezes tab to edit or freeze it."/>
                    </Border>
                    <DataGrid ItemsSource="{Binding Results}" SelectedItem="{Binding SelectedResult}"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="True" HeadersVisibility="Column" Margin="0,6,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Address" Binding="{Binding AddressHex}" Width="220"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Freezes -->
            <TabItem Header="Freezes">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F6F6F6" Padding="6">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Freeze all" Command="{Binding FreezeAllCommand}"/>
                            <Button Content="Remove selected" Command="{Binding RemoveFrozenCommand}"/>
                            <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555"
                                       Text="Edit Target to poke a value; tick Freeze to re-write it every ~200 ms."/>
                        </StackPanel>
                    </Border>
                    <DataGrid ItemsSource="{Binding Frozen}" SelectedItem="{Binding SelectedFrozen}"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" Margin="0,6,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Address" Binding="{Binding AddressHex}" IsReadOnly="True" Width="200"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding WidthLabel}" IsReadOnly="True" Width="70"/>
                            <DataGridTextColumn Header="Live" Binding="{Binding Live}" IsReadOnly="True" Width="90"/>
                            <DataGridTextColumn Header="Target"
                                                Binding="{Binding Target, UpdateSourceTrigger=LostFocus}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Freeze" Binding="{Binding Frozen}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Unit Reference -->
            <TabItem Header="Unit Reference">
                <DataGrid ItemsSource="{Binding Units}" AutoGenerateColumns="False" CanUserAddRows="False"
                          CanUserDeleteRows="False" IsReadOnly="True" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Unit" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="70"/>
                        <DataGridTextColumn Header="Cost" Binding="{Binding Cost}" Width="55"/>
                        <DataGridTextColumn Header="Move" Binding="{Binding Move}" Width="60"/>
                        <DataGridTextColumn Header="Bombard" Binding="{Binding Bombard}" Width="70"/>
                        <DataGridTextColumn Header="HP" Binding="{Binding HitPoints}" Width="45"/>
                        <DataGridTextColumn Header="Damage" Binding="{Binding Damage}" Width="75"/>
                        <DataGridCheckBoxColumn Header="Repair" Binding="{Binding Repairable}" Width="55"/>
                        <DataGridCheckBoxColumn Header="AA" Binding="{Binding AntiAir}" Width="40"/>
                        <DataGridTextColumn Header="Attack" Binding="{Binding AttackStyle}" Width="65"/>
                        <DataGridTextColumn Header="Defense" Binding="{Binding DefenseStyle}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
