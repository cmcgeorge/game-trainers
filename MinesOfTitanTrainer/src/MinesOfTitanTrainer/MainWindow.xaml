<Window x:Class="MinesOfTitanTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mines of Titan Trainer" Height="680" Width="880"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0,4,0"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#EEE" Padding="6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Process:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="280" ItemsSource="{Binding Processes}" DisplayMemberPath="Display"
                          SelectedItem="{Binding SelectedProcess}"/>
                <Button Content="Refresh" Command="{Binding RefreshProcessesCommand}"/>
                <Button Content="Attach" Command="{Binding AttachCommand}"/>
                <Button Content="Detach" Command="{Binding DetachCommand}"/>
                <Button Content="Re-scan" Command="{Binding ScanCommand}"/>
            </StackPanel>
        </Border>

        <!-- Party-wide actions -->
        <Border DockPanel.Dock="Top" Background="#F6F6F6" Padding="6">
            <StackPanel Orientation="Horizontal">
                <CheckBox Content="Freeze Credits" IsChecked="{Binding FreezeCredits}" VerticalAlignment="Center" Margin="4,0"/>
                <Separator Style="{x:Null}" Width="12"/>
                <Button Content="Max Attributes" Command="{Binding MaxAttributesPartyCommand}"/>
                <Button Content="Max Skills" Command="{Binding MaxSkillsPartyCommand}"/>
                <Button Content="Max Credits" Command="{Binding MaxCreditsPartyCommand}"/>
                <Button Content="Max Everything" Command="{Binding MaxEverythingPartyCommand}"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#EEE" Padding="6">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
        </Border>

        <!-- Party + character editor -->
        <Grid Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Party">
                <ListBox ItemsSource="{Binding Party}" SelectedItem="{Binding SelectedCharacter}"
                         DisplayMemberPath="ListLabel"/>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Character" Margin="6,0,0,0"
                      DataContext="{Binding SelectedCharacter}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="6">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding Summary}" Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Name}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Sex" Style="{StaticResource FieldLabel}"/>
                            <ComboBox  Grid.Row="0" Grid.Column="3" Margin="2" ItemsSource="{Binding SexOptions}"
                                       SelectedIndex="{Binding SexIndex}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Age" Style="{StaticResource FieldLabel}"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Age}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Credits" Style="{StaticResource FieldLabel}"/>
                            <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding Credits}"/>
                        </Grid>

                        <!-- Per-character quick actions -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Max Attributes" Click="MaxAttributes_Click"/>
                            <Button Content="Max Skills" Click="MaxSkills_Click"/>
                            <Button Content="Max Credits" Click="MaxCredits_Click"/>
                            <Button Content="Max Everything" Click="MaxEverything_Click"/>
                        </StackPanel>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <GroupBox Grid.Column="0" Header="Attributes (0-15)" Margin="0,0,3,0">
                                <ItemsControl ItemsSource="{Binding Attributes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                                <TextBox   Grid.Column="1" Text="{Binding Value}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>

                            <GroupBox Grid.Column="1" Header="Skills" Margin="3,0,0,0">
                                <ItemsControl ItemsSource="{Binding Skills}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                                <TextBox   Grid.Column="1" Text="{Binding Value}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
