<Window x:Class="SyndicateTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Syndicate Plus Trainer" Height="660" Width="560"
        MinHeight="600" MinWidth="500"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="SYNDICATE PLUS TRAINER" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}" FontFamily="Consolas"/>
            <TextBlock Text="DOSBox-X memory trainer • built from Ghidra reverse-engineering"
                       Foreground="{StaticResource SubtleBrush}" FontSize="11" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Connection panel -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="6"
                Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="DOSBox-X process"
                           Foreground="{StaticResource SubtleBrush}" FontSize="11" Margin="0,0,0,4"/>

                <ComboBox x:Name="ProcessCombo" Grid.Row="1" Grid.Column="0" Height="30"
                          VerticalContentAlignment="Center"/>
                <Button x:Name="RefreshButton" Grid.Row="1" Grid.Column="1" Content="Refresh"
                        Margin="8,0,0,0" Click="RefreshButton_Click"/>
                <Button x:Name="AttachButton" Grid.Row="1" Grid.Column="2" Content="Attach"
                        Margin="8,0,0,0" Click="AttachButton_Click"
                        Background="{StaticResource AccentDimBrush}"/>
            </Grid>
        </Border>

        <!-- Status line -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="6"
                Padding="12,10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="{StaticResource BadBrush}"
                         VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="Not attached" Margin="8,0,0,0"
                           VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
            </StackPanel>
        </Border>

        <!-- Cheats -->
        <Border Grid.Row="3" Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="14">
            <StackPanel>
                <TextBlock Text="BUDGET / MONEY" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                           FontFamily="Consolas" Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Current:" Foreground="{StaticResource SubtleBrush}"
                               VerticalAlignment="Center" Width="70"/>
                    <TextBlock x:Name="MoneyText" Text="—" FontSize="20" FontWeight="Bold"
                               FontFamily="Consolas" Foreground="{StaticResource GoodBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="DateText" Text="" Foreground="{StaticResource SubtleBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0" FontFamily="Consolas"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Set to:" Foreground="{StaticResource SubtleBrush}"
                               VerticalAlignment="Center" Width="70"/>
                    <TextBox x:Name="MoneyInput" Width="150" Height="30" Text="1000000"
                             VerticalContentAlignment="Center" FontFamily="Consolas"/>
                    <Button x:Name="SetButton" Content="Set" Margin="8,0,0,0" Width="70"
                            Click="SetButton_Click" IsEnabled="False"/>
                    <Button x:Name="Add100kButton" Content="+100k" Margin="8,0,0,0"
                            Click="Add100kButton_Click" IsEnabled="False"/>
                    <Button x:Name="MaxButton" Content="Max" Margin="8,0,0,0"
                            Click="MaxButton_Click" IsEnabled="False"/>
                </StackPanel>

                <CheckBox x:Name="FreezeCheck" Content="Freeze money (keep topped up while spending)"
                          IsEnabled="False" Checked="FreezeCheck_Changed" Unchecked="FreezeCheck_Changed"
                          Margin="0,4,0,0"/>
                <TextBlock Foreground="{StaticResource SubtleBrush}" FontSize="11" Margin="20,4,0,0"
                           TextWrapping="Wrap"
                           Text="With Freeze on, the trainer re-writes your target amount ~4×/sec so purchases, research and mods never actually reduce your balance."/>
            </StackPanel>
        </Border>

        <!-- Agent health (in-mission) -->
        <Border Grid.Row="4" Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="14" Margin="0,10,0,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="AGENT HEALTH" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                               FontFamily="Consolas"/>
                    <TextBlock Text="(in-mission only)" Foreground="{StaticResource SubtleBrush}"
                               FontSize="11" Margin="8,0,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>

                <UniformGrid x:Name="HealthGrid" Columns="4" Margin="0,0,0,10">
                    <Border Margin="0,0,4,0" Background="#0B0E13" CornerRadius="4" Padding="6">
                        <StackPanel>
                            <TextBlock Text="Agent 1" Foreground="{StaticResource SubtleBrush}" FontSize="10"/>
                            <TextBlock x:Name="Hp1" Text="—" FontFamily="Consolas" FontSize="15"
                                       Foreground="{StaticResource GoodBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Margin="2,0,2,0" Background="#0B0E13" CornerRadius="4" Padding="6">
                        <StackPanel>
                            <TextBlock Text="Agent 2" Foreground="{StaticResource SubtleBrush}" FontSize="10"/>
                            <TextBlock x:Name="Hp2" Text="—" FontFamily="Consolas" FontSize="15"
                                       Foreground="{StaticResource GoodBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Margin="2,0,2,0" Background="#0B0E13" CornerRadius="4" Padding="6">
                        <StackPanel>
                            <TextBlock Text="Agent 3" Foreground="{StaticResource SubtleBrush}" FontSize="10"/>
                            <TextBlock x:Name="Hp3" Text="—" FontFamily="Consolas" FontSize="15"
                                       Foreground="{StaticResource GoodBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Margin="4,0,0,0" Background="#0B0E13" CornerRadius="4" Padding="6">
                        <StackPanel>
                            <TextBlock Text="Agent 4" Foreground="{StaticResource SubtleBrush}" FontSize="10"/>
                            <TextBlock x:Name="Hp4" Text="—" FontFamily="Consolas" FontSize="15"
                                       Foreground="{StaticResource GoodBrush}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="HealButton" Content="Heal All (4096)" Click="HealButton_Click"
                            IsEnabled="False" Width="130"/>
                    <CheckBox x:Name="GodModeCheck" Content="Freeze health (god mode)" Margin="16,0,0,0"
                              IsEnabled="False" Checked="GodModeCheck_Changed" Unchecked="GodModeCheck_Changed"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <CheckBox x:Name="InfiniteAmmoCheck" Content="Freeze ammo (infinite)"
                              IsEnabled="False" Checked="InfiniteAmmoCheck_Changed" Unchecked="InfiniteAmmoCheck_Changed"/>
                    <TextBlock x:Name="AmmoStatus" Text="" Foreground="{StaticResource SubtleBrush}"
                               FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <CheckBox x:Name="NoRecoilCheck" Content="No recoil (stop knock-back when shot)"
                              IsEnabled="False" Checked="NoRecoilCheck_Changed" Unchecked="NoRecoilCheck_Changed"/>
                    <TextBlock x:Name="RecoilStatus" Text="" Foreground="{StaticResource SubtleBrush}"
                               FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Foreground="{StaticResource SubtleBrush}" FontSize="11" Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           Text="Health only affects alive agents (dead/empty slots untouched; full = 4096). Ammo keeps your squad's carried weapons topped up so they never run dry. No recoil resets the hit-reaction fields each tick, so shots no longer knock your agents back."/>
            </StackPanel>
        </Border>

        <!-- Log -->
        <Border Grid.Row="5" Background="#0B0E13" CornerRadius="6" Padding="8" Margin="0,10,0,10">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" Foreground="{StaticResource SubtleBrush}"
                           FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <TextBlock Grid.Row="6" Foreground="{StaticResource AccentDimBrush}" FontSize="10"
                   TextWrapping="Wrap"
                   Text="Budget = int32 @ game VA 0x5E49C. Agent health = int16 @ 0x6C123 + k*0x5C. Located by scanning for the PERSUADERTRON data-segment signature; verified against the purchase/save routines and live memory."/>
    </Grid>
</Window>
