<Window x:Class="DragonWarsTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dragon Wars Trainer" Height="680" Width="920"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Padding" Value="2,1"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0,4,0"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#EEE" Padding="6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Process:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="280" ItemsSource="{Binding Processes}" DisplayMemberPath="Display"
                          SelectedItem="{Binding SelectedProcess}"/>
                <Button Content="Refresh" Command="{Binding RefreshProcessesCommand}"/>
                <Button Content="Attach" Command="{Binding AttachCommand}"/>
                <Button Content="Detach" Command="{Binding DetachCommand}"/>
                <Button Content="Re-scan" Command="{Binding ScanCommand}"/>
            </StackPanel>
        </Border>

        <!-- Party-wide actions -->
        <Border DockPanel.Dock="Top" Background="#F6F6F6" Padding="6">
            <StackPanel Orientation="Horizontal">
                <CheckBox Content="Freeze Health" IsChecked="{Binding FreezeHealth}" VerticalAlignment="Center" Margin="4,0"/>
                <CheckBox Content="Freeze Stun" IsChecked="{Binding FreezeStun}" VerticalAlignment="Center" Margin="4,0"/>
                <CheckBox Content="Freeze Power" IsChecked="{Binding FreezePower}" VerticalAlignment="Center" Margin="4,0"/>
                <Separator Style="{x:Null}" Width="12"/>
                <Button Content="Heal Party" Command="{Binding HealPartyCommand}"/>
                <Button Content="Max Attributes" Command="{Binding MaxPartyCommand}"/>
                <Button Content="Learn Spells" Command="{Binding LearnSpellsPartyCommand}"/>
                <Button Content="Max Money" Command="{Binding MaxMoneyPartyCommand}"/>
                <Button Content="Max Everything" Command="{Binding MaxEverythingPartyCommand}"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#EEE" Padding="6">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
        </Border>

        <!-- Main content -->
        <Grid Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Party list -->
            <GroupBox Grid.Column="0" Header="Party">
                <ListBox ItemsSource="{Binding Party}" SelectedItem="{Binding SelectedCharacter}"
                         DisplayMemberPath="ListLabel"/>
            </GroupBox>

            <!-- Character detail -->
            <GroupBox Grid.Column="1" Header="Character" Margin="6,0,0,0"
                      DataContext="{Binding SelectedCharacter}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="6">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding Summary}" Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <!-- Identity -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Name}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Gender" Style="{StaticResource FieldLabel}"/>
                            <ComboBox  Grid.Row="0" Grid.Column="3" Margin="2" ItemsSource="{Binding GenderOptions}"
                                       SelectedIndex="{Binding GenderIndex}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Level" Style="{StaticResource FieldLabel}"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Level}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Experience" Style="{StaticResource FieldLabel}"/>
                            <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding Experience}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Gold" Style="{StaticResource FieldLabel}"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding Gold}"/>
                        </Grid>

                        <!-- Vitals -->
                        <GroupBox Header="Vitals" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Health" Style="{StaticResource FieldLabel}"/>
                                <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding HealthCurrent}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="/ Max" Style="{StaticResource FieldLabel}"/>
                                <TextBox   Grid.Row="0" Grid.Column="3" Text="{Binding HealthMax}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Stun" Style="{StaticResource FieldLabel}"/>
                                <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding StunCurrent}"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="/ Max" Style="{StaticResource FieldLabel}"/>
                                <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding StunMax}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Power" Style="{StaticResource FieldLabel}"/>
                                <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding PowerCurrent}"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="/ Max" Style="{StaticResource FieldLabel}"/>
                                <TextBox   Grid.Row="2" Grid.Column="3" Text="{Binding PowerMax}"/>
                            </Grid>
                        </GroupBox>

                        <!-- Combat -->
                        <GroupBox Header="Combat" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="AV" Style="{StaticResource FieldLabel}"/>
                                <TextBox Width="60" Text="{Binding ArmorValue}"/>
                                <TextBlock Text="DV" Style="{StaticResource FieldLabel}"/>
                                <TextBox Width="60" Text="{Binding DefenseValue}"/>
                                <TextBlock Text="AC" Style="{StaticResource FieldLabel}"/>
                                <TextBox Width="60" Text="{Binding ArmorClass}"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Attributes -->
                        <GroupBox Header="Attributes" Margin="0,8,0,0">
                            <ItemsControl ItemsSource="{Binding Attributes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="4">
                                            <TextBlock Text="{Binding Name}" Width="40" VerticalAlignment="Center"/>
                                            <TextBox Width="60" Text="{Binding Value}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <!-- Skills -->
                        <GroupBox Header="Skills" Margin="0,8,0,0">
                            <ItemsControl ItemsSource="{Binding Skills}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="4,2" Width="200">
                                            <TextBlock Text="{Binding Name}" Width="120" VerticalAlignment="Center"/>
                                            <TextBox Width="55" Text="{Binding Value}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <!-- Per-character actions -->
                        <WrapPanel Margin="0,8,0,0">
                            <Button Content="Full Heal" Click="FullHeal_Click"/>
                            <Button Content="Max Attributes" Click="MaxAttributes_Click"/>
                            <Button Content="Max Skills" Click="MaxSkills_Click"/>
                            <Button Content="Learn All Spells" Click="LearnSpells_Click"/>
                            <Button Content="Max Money" Click="MaxMoney_Click"/>
                            <Button Content="Max Everything" Click="MaxEverything_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
