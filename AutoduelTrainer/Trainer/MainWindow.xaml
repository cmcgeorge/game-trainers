<Window x:Class="AutoduelTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AutoduelTrainer"
        Title="Autoduel Trainer" Height="760" Width="880"
        MinHeight="600" MinWidth="720"
        Background="{StaticResource Bg}"
        FontFamily="Segoe UI" FontSize="13">

    <DockPanel>

        <!-- Title bar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1" Padding="16,12">
            <StackPanel>
                <TextBlock Text="AUTODUEL TRAINER" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource Accent}"/>
                <TextBlock Text="Live memory editor for AUTODUEL (Origin, 1985) running under DOSBox-X"
                           Foreground="{StaticResource TextDim}" FontSize="12" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Stroke}" BorderThickness="0,1,0,0" Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Status}" TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource TextDim}" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="{Binding AddressInfo}" FontFamily="Consolas"
                           Foreground="{StaticResource TextDim}" FontSize="11" Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- Connection strip -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="6,8,6,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="DOSBox process" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Processes}"
                          SelectedItem="{Binding Selected}" MinWidth="240"/>
                <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshProcessesCommand}" Margin="8,0,6,0"/>
                <Button Grid.Column="3" Content="Attach" Style="{StaticResource AccentButton}"
                        Command="{Binding AttachCommand}" Margin="0,0,6,0"/>
                <Button Grid.Column="4" Content="Re-scan" Command="{Binding RescanCommand}"
                        ToolTip="Re-locate the driver record (use after loading/switching drivers)" Margin="0,0,6,0"/>
                <Button Grid.Column="5" Content="Detach" Command="{Binding DetachCommand}" Margin="0,0,12,0"/>
                <CheckBox Grid.Column="6" Content="Auto-refresh" IsChecked="{Binding AutoRefresh}"/>
            </Grid>
        </Border>

        <!-- Main content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid IsEnabled="{Binding Attached}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===================== DRIVER ===================== -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="DRIVER" Style="{StaticResource Header}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Name" Style="{StaticResource Label}" Grid.Row="0"/>
                            <TextBlock Text="{Binding DriverName}" Grid.Row="0" Grid.Column="1"
                                       FontFamily="Consolas" FontWeight="SemiBold"/>

                            <TextBlock Text="Money $" Style="{StaticResource Label}" Grid.Row="1"/>
                            <TextBox Text="{Binding Money, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="1" Grid.Column="1" Margin="0,3"/>
                            <CheckBox Grid.Row="1" Grid.Column="2" Content="Freeze" Margin="8,0,0,0"
                                      IsChecked="{Binding FreezeMoney}"
                                      ToolTip="Keep money locked at this value"/>

                            <TextBlock Text="Prestige" Style="{StaticResource Label}" Grid.Row="2"/>
                            <TextBox Text="{Binding Prestige, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="2" Grid.Column="1" Margin="0,3"/>

                            <TextBlock Text="Health (max 3)" Style="{StaticResource Label}" Grid.Row="3"/>
                            <TextBox Text="{Binding Health, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="3" Grid.Column="1" Margin="0,3"/>
                            <CheckBox Grid.Row="3" Grid.Column="2" Content="Freeze" Margin="8,0,0,0"
                                      IsChecked="{Binding FreezeHealth}"
                                      ToolTip="Keep health locked at this value"/>

                            <TextBlock Text="Body Armor" Style="{StaticResource Label}" Grid.Row="4"/>
                            <TextBox Text="{Binding BodyArmor, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="4" Grid.Column="1" Margin="0,3"/>

                            <TextBlock Text="Driving skill" Style="{StaticResource Label}" Grid.Row="5"/>
                            <TextBox Text="{Binding Driving, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="5" Grid.Column="1" Margin="0,3"/>

                            <TextBlock Text="Marksmanship" Style="{StaticResource Label}" Grid.Row="6"/>
                            <TextBox Text="{Binding Marksmanship, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="6" Grid.Column="1" Margin="0,3"/>

                            <TextBlock Text="Mechanic" Style="{StaticResource Label}" Grid.Row="7"/>
                            <TextBox Text="{Binding Mechanic, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="7" Grid.Column="1" Margin="0,3"/>

                            <TextBlock Text="Current location" Style="{StaticResource Label}" Grid.Row="8"/>
                            <TextBlock Text="{Binding CurrentLocation}" Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2"
                                       FontFamily="Consolas" FontWeight="SemiBold"/>

                            <TextBlock Text="Teleport to" Style="{StaticResource Label}" Grid.Row="9"/>
                            <DockPanel Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,3">
                                <Button DockPanel.Dock="Right" Content="Teleport" Margin="6,0,0,0"
                                        Command="{Binding TeleportCommand}"
                                        ToolTip="Set your location to the selected city, then save &amp; reload in the game to apply it there"/>
                                <ComboBox ItemsSource="{Binding Cities}"
                                          DisplayMemberPath="Name" SelectedValuePath="Id"
                                          SelectedValue="{Binding CityIndex, Mode=TwoWay}"/>
                            </DockPanel>

                            <TextBlock Text="Date (day)" Style="{StaticResource Label}" Grid.Row="10"/>
                            <DockPanel Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,3">
                                <TextBox DockPanel.Dock="Left" Width="70"
                                         Text="{Binding Day, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Day counter — days since 1 Jan 2030; click Apply Driver to write it"/>
                                <TextBlock Text="{Binding DateInfo}" Margin="8,0,0,0" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextDim}" FontSize="12"/>
                            </DockPanel>

                            <TextBlock Text="Time of day" Style="{StaticResource Label}" Grid.Row="11"/>
                            <TextBox Text="{Binding TimeOfDay, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="11" Grid.Column="1" Margin="0,3"
                                     ToolTip="Time counter — advances while driving; higher values bring on the evening"/>
                            <CheckBox Grid.Row="11" Grid.Column="2" Content="Freeze" Margin="8,0,0,0"
                                      IsChecked="{Binding FreezeTimeOfDay}"
                                      ToolTip="Hold the time so the game stays in daytime — no more &quot;closed for the evening&quot;. Tick this while it is daytime."/>
                        </Grid>

                        <CheckBox Margin="0,8,0,0" IsChecked="{Binding AutoReloadAfterTeleport}"
                                  Content="Auto save+load in game after teleport"
                                  ToolTip="After teleporting, send the game q y y 1 4 (Quit → reload driver 4) so the new city takes effect. Start from the main city menu."/>

                        <Separator Margin="0,10" Background="{StaticResource Stroke}"/>
                        <WrapPanel>
                            <Button Content="Apply Driver" Style="{StaticResource AccentButton}"
                                    Command="{Binding ApplyPlayerCommand}"/>
                            <Button Content="Max Money" Command="{Binding MaxMoneyCommand}"/>
                            <Button Content="Max Skills" Command="{Binding MaxSkillsCommand}"/>
                            <Button Content="Full Health" Command="{Binding FullHealthCommand}"/>
                            <Button Content="Reload Game" Command="{Binding ReloadGameCommand}"
                                    ToolTip="Send q y y 1 4 to the game (Quit → reload driver 4) to apply a teleport. Use from the main city menu."/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- ===================== CAR ===================== -->
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="CAR" Style="{StaticResource Header}"/>
                        <TextBlock Text="{Binding CarName}" FontFamily="Consolas" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CarInfo}" Foreground="{StaticResource TextDim}"
                                   FontSize="12" Margin="0,2,0,8" TextWrapping="Wrap"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Battery" Style="{StaticResource Label}" Grid.Row="0"/>
                            <TextBox Text="{Binding Battery, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="0" Grid.Column="1" Margin="0,3"/>
                            <TextBlock Text="/" Grid.Row="0" Grid.Column="2" Margin="6,0"
                                       Foreground="{StaticResource TextDim}"/>
                            <TextBox Text="{Binding BatteryMax, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="0" Grid.Column="3" Margin="0,3" HorizontalAlignment="Left" Width="70"
                                     ToolTip="Battery maximum"/>

                            <TextBlock Text="Max weight (lb)" Style="{StaticResource Label}" Grid.Row="1"/>
                            <TextBox Text="{Binding MaxWeight, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="1" Grid.Column="1" Margin="0,3"/>
                            <TextBlock Text="left" Grid.Row="1" Grid.Column="2" Margin="6,0"
                                       Foreground="{StaticResource TextDim}"/>
                            <TextBox Text="{Binding WeightLeft, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="1" Grid.Column="3" Margin="0,3" HorizontalAlignment="Left" Width="70"
                                     ToolTip="Weight capacity remaining"/>

                            <TextBlock Text="Max spaces" Style="{StaticResource Label}" Grid.Row="2"/>
                            <TextBox Text="{Binding MaxSpaces, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="2" Grid.Column="1" Margin="0,3"/>
                            <TextBlock Text="left" Grid.Row="2" Grid.Column="2" Margin="6,0"
                                       Foreground="{StaticResource TextDim}"/>
                            <TextBox Text="{Binding SpacesLeft, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="2" Grid.Column="3" Margin="0,3" HorizontalAlignment="Left" Width="70"
                                     ToolTip="Cargo spaces remaining"/>

                            <TextBlock Text="Handling" Style="{StaticResource Label}" Grid.Row="3"/>
                            <TextBox Text="{Binding Handling, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="3" Grid.Column="1" Margin="0,3"/>
                            <TextBlock Text="accel" Grid.Row="3" Grid.Column="2" Margin="6,0"
                                       Foreground="{StaticResource TextDim}"/>
                            <TextBox Text="{Binding Acceleration, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="3" Grid.Column="3" Margin="0,3" HorizontalAlignment="Left" Width="70"
                                     ToolTip="Acceleration"/>

                            <TextBlock Text="Suspension" Style="{StaticResource Label}" Grid.Row="4"/>
                            <TextBox Text="{Binding Suspension, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="4" Grid.Column="1" Margin="0,3"
                                     ToolTip="Suspension type index (1 = Improved observed)"/>
                            <TextBlock Text="chassis" Grid.Row="4" Grid.Column="2" Margin="6,0"
                                       Foreground="{StaticResource TextDim}"/>
                            <TextBox Text="{Binding Chassis, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="4" Grid.Column="3" Margin="0,3" HorizontalAlignment="Left" Width="70"
                                     ToolTip="Chassis type index (0 = Light observed)"/>
                        </Grid>

                        <Grid Margin="0,3,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Car value $" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding CarValue, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Column="1" Margin="0,3"/>
                        </Grid>

                        <WrapPanel Margin="0,6,0,0">
                            <Button Content="Apply Car" Style="{StaticResource AccentButton}"
                                    Command="{Binding ApplyCarCommand}"/>
                            <Button Content="Charge Battery" Command="{Binding ChargeBatteryCommand}"/>
                            <Button Content="Reload Weapons" Command="{Binding ReloadWeaponsCommand}"/>
                            <Button Content="Repair All" Command="{Binding RepairAllCommand}"/>
                        </WrapPanel>

                        <CheckBox Margin="0,4,0,0" IsChecked="{Binding FreezeCarStats}"
                                  Content="Freeze car stats (full battery, ammo, armor, no damage)"
                                  ToolTip="Continuously refill battery/ammo and repair all damage"/>

                        <DockPanel Margin="0,14,0,6">
                            <Button DockPanel.Dock="Right" Content="Apply Weapons"
                                    Style="{StaticResource AccentButton}" Margin="0"
                                    Command="{Binding ApplyWeaponsCommand}"
                                    ToolTip="Write the edited weapon type / facing / DP / ammo back into the game"/>
                            <TextBlock Text="WEAPONS" Style="{StaticResource Header}" Margin="0"/>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding Weapons}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource PanelHi}" CornerRadius="4"
                                            Padding="8,6" Margin="0,0,0,4"
                                            BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>

                                            <ComboBox Grid.Row="0" Grid.Column="0" Margin="0,0,6,4"
                                                      ItemsSource="{Binding DataContext.WeaponTypes,
                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      DisplayMemberPath="Name" SelectedValuePath="Id"
                                                      SelectedValue="{Binding Type, Mode=TwoWay}"
                                                      ToolTip="Weapon type"/>
                                            <ComboBox Grid.Row="0" Grid.Column="1" Width="92" Margin="0,0,0,4"
                                                      ItemsSource="{Binding DataContext.Facings,
                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      DisplayMemberPath="Name" SelectedValuePath="Id"
                                                      SelectedValue="{Binding Location, Mode=TwoWay}"
                                                      ToolTip="Facing"/>

                                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                        Orientation="Horizontal">
                                                <TextBlock Text="DP" Style="{StaticResource Label}" Margin="0,0,4,0"/>
                                                <TextBox Width="48"
                                                         Text="{Binding CurrentDp, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="Current damage points"/>
                                                <TextBlock Text="/" Margin="5,0"
                                                           Foreground="{StaticResource TextDim}"/>
                                                <TextBox Width="48"
                                                         Text="{Binding MaxDp, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="Max damage points"/>
                                                <TextBlock Text="Ammo" Style="{StaticResource Label}" Margin="16,0,4,0"/>
                                                <TextBox Width="64" IsEnabled="{Binding AmmoEditable}"
                                                         Text="{Binding Ammo, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="Rounds — self-powered weapons (laser, heavy rocket) are unlimited"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <DockPanel Margin="0,10,0,6">
                            <Button DockPanel.Dock="Right" Content="Apply Armor"
                                    Style="{StaticResource AccentButton}" Margin="0"
                                    Command="{Binding ApplyArmorCommand}"
                                    ToolTip="Write the edited armor DP back into the game"/>
                            <TextBlock Text="ARMOR" Style="{StaticResource Header}" Margin="0"/>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding Armor}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"
                                                   Text="{Binding ArmorLabel, Mode=OneWay}"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="DP" Style="{StaticResource Label}" Margin="0,0,4,0"/>
                                            <TextBox Width="48"
                                                     Text="{Binding CurrentDp, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="Current armor points"/>
                                            <TextBlock Text="/" Margin="5,0"
                                                       Foreground="{StaticResource TextDim}"/>
                                            <TextBox Width="48"
                                                     Text="{Binding MaxDp, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="Max armor points"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <DockPanel Margin="0,12,0,6">
                            <Button DockPanel.Dock="Right" Content="Apply Parts"
                                    Style="{StaticResource AccentButton}" Margin="0"
                                    Command="{Binding ApplyDrivetrainCommand}"
                                    ToolTip="Write the edited power-plant / tire DP back into the game"/>
                            <TextBlock Text="POWER PLANT &amp; TIRES" Style="{StaticResource Header}" Margin="0"/>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding Drivetrain}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"
                                                   Text="{Binding DrivetrainLabel, Mode=OneWay}"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="DP" Style="{StaticResource Label}" Margin="0,0,4,0"/>
                                            <TextBox Width="48"
                                                     Text="{Binding CurrentDp, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="Current durability"/>
                                            <TextBlock Text="/" Margin="5,0"
                                                       Foreground="{StaticResource TextDim}"/>
                                            <TextBox Width="48"
                                                     Text="{Binding MaxDp, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="Max durability"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
