<Application x:Class="KeefTrainer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- Palette -->
        <SolidColorBrush x:Key="Bg" Color="#FF14161C"/>
        <SolidColorBrush x:Key="Panel" Color="#FF1C2029"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#FF2B313F"/>
        <SolidColorBrush x:Key="Text" Color="#FFD8DBE2"/>
        <SolidColorBrush x:Key="TextDim" Color="#FF8A90A0"/>
        <SolidColorBrush x:Key="Gold" Color="#FFD4AF37"/>
        <SolidColorBrush x:Key="Accent" Color="#FF3E8E5A"/>
        <SolidColorBrush x:Key="AccentBright" Color="#FF52B878"/>
        <SolidColorBrush x:Key="Danger" Color="#FFB05050"/>
        <SolidColorBrush x:Key="FieldBg" Color="#FF10131A"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>

        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Gold}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
            <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
        </Style>

        <Style x:Key="StatName" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ValueBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource FieldBg}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBright}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource Text}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Gold}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FreezeToggle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTip" Value="Freeze this value"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Chip" Background="Transparent" BorderBrush="{StaticResource PanelBorder}"
                                BorderThickness="1" CornerRadius="3" Padding="5,1">
                            <TextBlock x:Name="Label" Text="❄" FontSize="12" Foreground="{StaticResource TextDim}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="#FF1F3D57"/>
                                <Setter TargetName="Chip" Property="BorderBrush" Value="#FF4E9BD8"/>
                                <Setter TargetName="Label" Property="Foreground" Value="#FF9FD4FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chip" Property="BorderBrush" Value="#FF4E9BD8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#FF232A38"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#FF2E3849"/>
                                <Setter TargetName="B" Property="BorderBrush" Value="{StaticResource Gold}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GroupPanel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
        </Style>

    </Application.Resources>
</Application>
