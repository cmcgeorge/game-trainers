<Window x:Class="RailroadTycoonTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Railroad Tycoon — Trainer" Height="780" Width="1020"
        Icon="Assets/app.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <TabControl Margin="6">
        <!-- ============================ LIVE SCANNER ============================ -->
        <TabItem Header="Live (Cash &amp; Value Scanner)" DataContext="{Binding Live}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#EEE" Padding="6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="DOSBox process:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox Width="300" ItemsSource="{Binding Processes}" DisplayMemberPath="Display"
                                  SelectedItem="{Binding SelectedProcess}"/>
                        <Button Content="Refresh" Command="{Binding RefreshProcessesCommand}"/>
                        <Button Content="Attach" Command="{Binding AttachCommand}"/>
                        <Button Content="Detach" Command="{Binding DetachCommand}"/>
                    </StackPanel>
                </Border>
                <Border DockPanel.Dock="Bottom" Background="#EEE" Padding="6">
                    <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
                </Border>

                <TabControl Margin="0,6,0,0">
                    <TabItem Header="Scan">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#F6F6F6" Padding="6">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Button Content="⚡ Auto-locate cash (no scan)" Command="{Binding AutoLocateCommand}"
                                                FontWeight="Bold"
                                                ToolTip="Finds the game's data segment by its label strings and pins your cash to the Freezes tab — no scanning."/>
                                        <Button Content="💰 Set max cash ($30M)" Command="{Binding MaxCashCommand}"
                                                ToolTip="Auto-locates cash if needed, sets it to the game's own $30,000,000 ceiling, and freezes it."/>
                                        <TextBlock Style="{StaticResource Hint}" VerticalAlignment="Center" Margin="8,0,0,0"
                                                   Text="One click each. The manual scan below is the fallback if your GAME.EXE build differs."/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Type:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <ComboBox Width="80" ItemsSource="{Binding Widths}" SelectedItem="{Binding SelectedWidth}"
                                                  IsEnabled="{Binding NotScanning}"
                                                  ToolTip="Byte, 16-bit or 32-bit. Changing this starts a new scan. Cash is Int16 (in $1,000s)."/>
                                        <TextBlock Text="Value:" VerticalAlignment="Center" Margin="10,0,4,0"/>
                                        <TextBox Width="120" Text="{Binding ScanText, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Decimal (1000) or hex (0x3E8). Leave blank for an unknown-value first scan."/>
                                        <Button Content="First Scan" Command="{Binding FirstScanCommand}"/>
                                        <Button Content="New Scan" Command="{Binding NewScanCommand}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Guides:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <Button Content="Cash" Command="{Binding CashGuideCommand}"
                                                ToolTip="Step-by-step to pin your cash by scanning (Int16, dollars ÷ 1000)."/>
                                        <Button Content="Any value" Command="{Binding ValueGuideCommand}"
                                                ToolTip="Step-by-step to pin any on-screen number you can watch change."/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Narrow:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <Button Content="Exact" Command="{Binding NextScanCommand}" CommandParameter="Exact"/>
                                        <Button Content="Increased" Command="{Binding NextScanCommand}" CommandParameter="Increased"/>
                                        <Button Content="Decreased" Command="{Binding NextScanCommand}" CommandParameter="Decreased"/>
                                        <Button Content="Changed" Command="{Binding NextScanCommand}" CommandParameter="Changed"/>
                                        <Button Content="Unchanged" Command="{Binding NextScanCommand}" CommandParameter="Unchanged"/>
                                        <TextBlock Text="{Binding MatchCount}" VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border DockPanel.Dock="Bottom" Background="#F6F6F6" Padding="6">
                                <Button Content="Pin selected →" Command="{Binding PinCommand}" HorizontalAlignment="Left"
                                        ToolTip="Add the selected candidate to the Freezes tab to edit or freeze it."/>
                            </Border>
                            <DataGrid ItemsSource="{Binding Results}" SelectedItem="{Binding SelectedResult}"
                                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                      IsReadOnly="True" HeadersVisibility="Column" Margin="0,6,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Address" Binding="{Binding AddressHex}" Width="240"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="Freezes">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#F6F6F6" Padding="6">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Freeze all" Command="{Binding FreezeAllCommand}"/>
                                    <Button Content="Unfreeze all" Command="{Binding FreezeNoneCommand}"/>
                                    <Button Content="Remove selected" Command="{Binding RemoveFrozenCommand}"/>
                                    <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#555"
                                               Text="Cash Target is in $1,000s (1000 = $1,000,000). Tick Freeze to re-write it every ~200 ms so the fiscal tick can't undo it."/>
                                </StackPanel>
                            </Border>
                            <DataGrid ItemsSource="{Binding Frozen}" SelectedItem="{Binding SelectedFrozen}"
                                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" Margin="0,6,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Label" Binding="{Binding Label}" IsReadOnly="True" Width="120"/>
                                    <DataGridTextColumn Header="Address" Binding="{Binding AddressHex}" IsReadOnly="True" Width="200"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding WidthLabel}" IsReadOnly="True" Width="60"/>
                                    <DataGridTextColumn Header="Live" Binding="{Binding Live}" IsReadOnly="True" Width="110"/>
                                    <DataGridTextColumn Header="Target" Binding="{Binding Target, UpdateSourceTrigger=LostFocus}" Width="*"/>
                                    <DataGridCheckBoxColumn Header="Freeze" Binding="{Binding Frozen}" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </TabItem>

        <!-- ============================ REFERENCES ============================ -->
        <TabItem Header="References" DataContext="{Binding Reference}">
            <TabControl Margin="4">
                <TabItem Header="Locomotives">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Hint}" Margin="6"
                                   Text="The buyable engine roster (names as the buy-list shows them). The startup quiz shows one of these to identify — match its wheel arrangement and era. The quiz calls the Mallet &quot;Challenger&quot; and the F-Series &quot;F3A-Series&quot;. Speed is mph; price is $."/>
                        <DataGrid ItemsSource="{Binding Locomotives}" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Region" Binding="{Binding Region}" Width="110"/>
                                <DataGridTextColumn Header="Locomotive" Binding="{Binding Name}" Width="200"/>
                                <DataGridTextColumn Header="Speed" Binding="{Binding SpeedMph}" Width="70"/>
                                <DataGridTextColumn Header="HP" Binding="{Binding Horsepower}" Width="70"/>
                                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="90"/>
                                <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Stations &amp; scenarios">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8">
                            <TextBlock Text="Station types" FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                            <DataGrid ItemsSource="{Binding Stations}" AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Name}" Width="140"/>
                                    <DataGridTextColumn Header="Cost" Binding="{Binding Cost}" Width="90"/>
                                    <DataGridTextColumn Header="Radius" Binding="{Binding Radius}" Width="70"/>
                                    <DataGridTextColumn Header="Coverage" Binding="{Binding Coverage}" Width="90"/>
                                    <DataGridTextColumn Header="Maint./yr" Binding="{Binding Maintenance}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="Station improvements" FontWeight="Bold" FontSize="13" Margin="0,10,0,4"/>
                            <DataGrid ItemsSource="{Binding Improvements}" AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Improvement" Binding="{Binding Name}" Width="160"/>
                                    <DataGridTextColumn Header="Cost" Binding="{Binding Cost}" Width="90"/>
                                    <DataGridTextColumn Header="Effect" Binding="{Binding Effect}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="Scenarios" FontWeight="Bold" FontSize="13" Margin="0,10,0,4"/>
                            <DataGrid ItemsSource="{Binding Scenarios}" AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Region" Binding="{Binding Name}" Width="180"/>
                                    <DataGridTextColumn Header="Start" Binding="{Binding StartYear}" Width="70"/>
                                    <DataGridTextColumn Header="Currency" Binding="{Binding Currency}" Width="80"/>
                                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="Difficulty levels" FontWeight="Bold" FontSize="13" Margin="0,10,0,4"/>
                            <DataGrid ItemsSource="{Binding Difficulties}" AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Level" Binding="{Binding Name}" Width="140"/>
                                    <DataGridTextColumn Header="Game length" Binding="{Binding GameYears}" Width="110"/>
                                    <DataGridTextColumn Header="Difficulty factor" Binding="{Binding DifficultyFactor}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="How it works / notes">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Notes}" Margin="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="{Binding Body}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </TabItem>
    </TabControl>
</Window>
