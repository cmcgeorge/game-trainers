<Window x:Class="SotSAgeTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SotSAgeTrainer.ViewModels"
        xmlns:inf="clr-namespace:SotSAgeTrainer.Infrastructure"
        Title="Sword of the Samurai — Trainer" Height="780" Width="660"
        Icon="Assets/app.ico"
        Background="#12151C" ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <inf:LifeStageLabelConverter x:Key="StageLabel"/>
        <inf:RoleBrushConverter x:Key="RoleBrush"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E6E9EF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1B2029"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="BorderBrush" Value="#2A313E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="Section" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A93A6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="Action" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2E3644"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Sword of the Samurai" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Live-memory trainer — freeze youth, max your stats, cripple rivals" Foreground="#8A93A6" FontSize="12"/>
        </StackPanel>

        <!-- Connection -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="14" Height="14" Fill="{Binding StatusBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ConnectionText}" Margin="10,0,0,0" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Age freeze -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource Section}" Text="AGE FREEZE"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PROTAGONIST AGE" Foreground="#8A93A6" FontSize="11"/>
                        <TextBlock Text="{Binding CurrentAgeText}" FontSize="18" FontWeight="SemiBold" Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding CurrentArmyText}" Foreground="#8A93A6" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Target:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="150" VerticalAlignment="Center" ItemsSource="{Binding TargetOptions}"
                                  SelectedItem="{Binding SelectedTarget, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource StageLabel}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="Apply once" Command="{Binding ApplyAgeOnceCommand}"
                                Style="{StaticResource Action}" Margin="10,0,0,0"/>
                    </StackPanel>
                </Grid>

                <ToggleButton IsChecked="{Binding IsFreezing, Mode=TwoWay}" Content="{Binding FreezeButtonText}"
                              Height="46" FontSize="15" FontWeight="SemiBold" Cursor="Hand" Margin="0,12,0,0">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="#3B7DD8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="#1FA463"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
            </StackPanel>
        </Border>

        <!-- Characters / stats -->
        <Border Grid.Row="3" Style="{StaticResource Card}">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource Section}" Text="CHARACTERS &amp; STATS" Margin="0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="★ Max my stats" Command="{Binding MaxMeCommand}"
                                Style="{StaticResource Action}" Background="#1FA463"/>
                        <Button Content="⚔ Boost army" Command="{Binding BoostArmyCommand}"
                                Style="{StaticResource Action}" Background="#2E7D66" Margin="8,0,0,0"/>
                        <Button Content="☠ Cripple rivals" Command="{Binding CrippleRivalsCommand}"
                                Style="{StaticResource Action}" Background="#C0553F" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- column header -->
                <Grid Margin="2,0,2,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="104"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="#" Foreground="#66707F" FontSize="11"/>
                    <TextBlock Grid.Column="1" Text="role" Foreground="#66707F" FontSize="11"/>
                    <TextBlock Grid.Column="2" Text="age" Foreground="#66707F" FontSize="11"/>
                    <TextBlock Grid.Column="3" Text="army" Foreground="#66707F" FontSize="11"/>
                    <TextBlock Grid.Column="4" Text="stats" Foreground="#66707F" FontSize="11"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding Roster}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#151A22" CornerRadius="5" Padding="2" Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="104"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Index}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding RoleText}" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Foreground="{Binding Role, Converter={StaticResource RoleBrush}}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AgeText}" VerticalAlignment="Center" Foreground="#B8C0CE"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Army}" VerticalAlignment="Center" FontFamily="Consolas" Foreground="#C9B98A"/>
                                    <TextBlock Grid.Column="4" Text="{Binding StatsText}" VerticalAlignment="Center"
                                               FontFamily="Consolas" Foreground="#9FB4C9"/>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="4,0,4,0">
                                        <Button Content="Max" Style="{StaticResource Action}" Padding="8,4" FontSize="11"
                                                Background="#274C39" CommandParameter="{Binding Index}"
                                                Command="{Binding DataContext.MaxRecordCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        <Button Content="Min" Style="{StaticResource Action}" Padding="8,4" FontSize="11" Margin="4,0,0,0"
                                                Background="#4C2A27" CommandParameter="{Binding Index}"
                                                Command="{Binding DataContext.MinRecordCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding StatusText}" Foreground="#B8C0CE" Margin="2,8,0,0" TextWrapping="Wrap"/>
                <TextBlock Text="YOU = record 0 · kin share your family index (left alone) · rivals = everyone else. Rival names aren't stored as text — confirm targets in-game."
                           Foreground="#5B6472" FontSize="11" TextWrapping="Wrap" Margin="2,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Log -->
        <Border Grid.Row="4" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Section}" Text="ACTIVITY"/>
                <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True" Background="Transparent"
                         Foreground="#9FB4C9" BorderThickness="0" FontFamily="Consolas" FontSize="12"
                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
            </DockPanel>
        </Border>

        <TextBlock Grid.Row="5" Foreground="#5B6472" FontSize="11" TextWrapping="Wrap"
                   Text="Signature MGRAPHIC.EXE\0RSOUND.SAM · records at base+0x6F, stride 0x60 · stats span R+0x3A…R+0x58 (2…128 → 0x80/0x01) · age R+0x33. Edits apply to every block copy; nothing is written to disk."/>
    </Grid>
</Window>
