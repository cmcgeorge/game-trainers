<Window x:Class="WastelandTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WastelandTrainer"
        Title="Wasteland Trainer" Height="720" Width="980"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">
    <Window.Resources>
        <local:MapScaleConverter x:Key="MapScale" Cell="10"/>
        <local:MapFlipYConverter x:Key="MapFlipY" Cell="10"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Padding" Value="2,1"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0,4,0"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>
        <Style x:Key="RefHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="2,6,2,2"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#EEE" Padding="6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Process:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="280" ItemsSource="{Binding Processes}" DisplayMemberPath="Display"
                          SelectedItem="{Binding SelectedProcess}"/>
                <Button Content="Refresh" Command="{Binding RefreshProcessesCommand}"/>
                <Button Content="Attach" Command="{Binding AttachCommand}"/>
                <Button Content="Detach" Command="{Binding DetachCommand}"/>
                <Button Content="Re-scan" Command="{Binding ScanCommand}"/>
            </StackPanel>
        </Border>

        <!-- Party-wide actions -->
        <Border DockPanel.Dock="Top" Background="#F6F6F6" Padding="6">
            <StackPanel Orientation="Horizontal">
                <CheckBox Content="Freeze Health (CON)" IsChecked="{Binding FreezeHealth}" VerticalAlignment="Center" Margin="4,0"
                          ToolTip="Keeps the whole party pinned to full constitution (CON = hit points) while exploring."/>
                <CheckBox Content="Freeze Ammo" IsChecked="{Binding FreezeAmmo}" VerticalAlignment="Center" Margin="4,0"
                          ToolTip="Tops every ranger's ammo — weapon rounds, clips, charges — up to 99 each tick, so it never runs low. Only weapons and ammo are touched; armor and quest items are left alone."/>
                <Separator Style="{x:Null}" Width="12"/>
                <Button Content="Heal Party" Command="{Binding HealPartyCommand}"/>
                <Button Content="Max Attributes" Command="{Binding MaxAttributesPartyCommand}"/>
                <Button Content="Max Skills" Command="{Binding MaxSkillsPartyCommand}"/>
                <Button Content="Max Money" Command="{Binding MaxMoneyPartyCommand}"/>
                <Button Content="Max Everything" Command="{Binding MaxEverythingPartyCommand}"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#EEE" Padding="6">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
        </Border>

        <!-- Tabs -->
        <TabControl Margin="6">
            <!-- ======================= PARTY ======================= -->
            <TabItem Header="Party">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="Rangers">
                        <ListBox ItemsSource="{Binding Party}" SelectedItem="{Binding SelectedCharacter}"
                                 DisplayMemberPath="ListLabel"/>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="Ranger" Margin="6,0,0,0"
                              DataContext="{Binding SelectedCharacter}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="6">
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding Summary}" Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="130"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Name}" MaxLength="13"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Gender" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox  Grid.Row="0" Grid.Column="3" Margin="2" ItemsSource="{Binding GenderOptions}"
                                               SelectedIndex="{Binding GenderIndex}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Level" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Level}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Nationality" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox  Grid.Row="1" Grid.Column="3" Margin="2" ItemsSource="{Binding NationalityOptions}"
                                               SelectedIndex="{Binding NationalityIndex}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Experience" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding Experience}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Money ($)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="2" Grid.Column="3" Text="{Binding Money}"/>
                                </Grid>

                                <GroupBox Header="Constitution &amp; progression" Margin="0,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="CON" Style="{StaticResource FieldLabel}"/>
                                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Con}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="/ Max" Style="{StaticResource FieldLabel}"/>
                                        <TextBox   Grid.Row="0" Grid.Column="3" Text="{Binding MaxCon}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Skill pts" Style="{StaticResource FieldLabel}"/>
                                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding SkillPoints}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Armor Cls" Style="{StaticResource FieldLabel}"/>
                                        <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding ArmorClass}"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Attributes" Margin="0,8,0,0">
                                    <ItemsControl ItemsSource="{Binding Attributes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="4">
                                                    <TextBlock Text="{Binding Name}" Width="40" VerticalAlignment="Center"
                                                               ToolTip="{Binding Description}"/>
                                                    <TextBox Width="60" Text="{Binding Value}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </GroupBox>

                                <GroupBox Header="Skills" Margin="0,8,0,0">
                                    <ItemsControl ItemsSource="{Binding Skills}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="4,2" Width="215">
                                                    <TextBlock Text="{Binding Name}" Width="135" VerticalAlignment="Center"
                                                               ToolTip="{Binding Description}"/>
                                                    <TextBox Width="55" Text="{Binding Level}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </GroupBox>

                                <WrapPanel Margin="0,8,0,0">
                                    <Button Content="Full Heal" Click="FullHeal_Click"/>
                                    <Button Content="Max Attributes" Click="MaxAttributes_Click"/>
                                    <Button Content="Max Skills" Click="MaxSkills_Click"/>
                                    <Button Content="Max Money" Click="MaxMoney_Click"/>
                                    <Button Content="Max Everything" Click="MaxEverything_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ======================= INVENTORY ======================= -->
            <TabItem Header="Inventory">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="Rangers">
                        <ListBox ItemsSource="{Binding Party}" SelectedItem="{Binding SelectedCharacter}"
                                 DisplayMemberPath="ListLabel"/>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="Carried Items" Margin="6,0,0,0"
                              DataContext="{Binding SelectedCharacter}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Foreground="#555" TextWrapping="Wrap" Margin="2,2,2,6"
                                       Text="Thirty inventory slots per ranger. Pick any of the game's 91 items from the drop-down, or type its name or a raw item id (0 = empty) straight into the box. Set the quantity/ammo, or Clear the slot. Items always pack to the top with no gaps (the way the game reads them), so a new item may jump to the first free row — that is expected. The item list is decoded from WL.EXE; any id outside it shows as &quot;Item #N&quot;."/>
                            <TextBlock DockPanel.Dock="Top" Margin="2,0,2,6" FontWeight="Bold"
                                       Text="{Binding Title}"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="2,3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="28"/>
                                                        <ColumnDefinition Width="260"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="55"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding SlotLabel}" VerticalAlignment="Center" Foreground="#888"/>
                                                    <ComboBox  Grid.Column="1" Margin="2" IsEditable="True" StaysOpenOnEdit="True"
                                                               IsTextSearchEnabled="False" ItemsSource="{Binding Options}"
                                                               DisplayMemberPath="Label"
                                                               Text="{Binding Selection, UpdateSourceTrigger=LostFocus}"
                                                               SelectionChanged="ItemSelected"
                                                               ToolTip="Pick an item, or type its name or a raw item id (0 = empty)"/>
                                                    <TextBlock Grid.Column="2" Text="Qty" Style="{StaticResource FieldLabel}" MinWidth="0"/>
                                                    <TextBox   Grid.Column="3" Text="{Binding Quantity}"
                                                               ToolTip="Ammunition / charge / quantity byte"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding Name}" Foreground="#555"
                                                               VerticalAlignment="Center" Margin="8,0" TextTrimming="CharacterEllipsis"/>
                                                    <Button    Grid.Column="5" Content="Clear" Click="ClearItem_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ======================= REFERENCES ======================= -->
            <TabItem Header="References">
                <TabControl Margin="6" DataContext="{Binding Reference}">
                    <!-- Attributes -->
                    <TabItem Header="Attributes">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Foreground="#555" TextWrapping="Wrap" Margin="2,2,2,6"
                                       Text="What each of the seven attributes does in the game, and how it matters when building a ranger. 'Role' follows the game manual; 'In play' follows the bundled strategy guide."/>
                            <ListBox ItemsSource="{Binding Attributes}" HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="55"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Abbr}" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="#777" VerticalAlignment="Top"/>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Role}" TextWrapping="Wrap" Foreground="#444"/>
                                                <TextBlock Text="{Binding InPlay}" TextWrapping="Wrap" Foreground="#1565C0" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- Skills -->
                    <TabItem Header="Skills">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Foreground="#555" TextWrapping="Wrap" Margin="2,2,2,6"
                                       Text="What each of the 35 skills does, where in the game it's notably used, and the IQ needed to learn its first level. A fresh ranger starts with skill points equal to IQ, and each extra level of a skill costs progressively more — but skills also improve just from being used. Combat and weapon skills apply in any fight, so no single location is listed for them."/>
                            <ListBox ItemsSource="{Binding Skills}" HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="170"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Id}" Foreground="#999" VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Top" TextWrapping="Wrap"/>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Use}" TextWrapping="Wrap" Foreground="#444"/>
                                                <TextBlock TextWrapping="Wrap" Foreground="#1565C0" Margin="0,2,0,0">
                                                    <Run Text="Where used:" FontWeight="SemiBold"/>
                                                    <Run Text="{Binding Where}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Requirement}" Foreground="#777" FontSize="11" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- Items -->
                    <TabItem Header="Items">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Foreground="#555" TextWrapping="Wrap" Margin="2,2,2,6"
                                       Text="Every item the game stores by id (decoded from WL.EXE), grouped by type, with a short note on what it is or does. These same ids and names drive the Inventory tab's drop-down. Weapons also list their damage as six-sided dice (e.g. 4d6) — but each point of the target's Armor Class cancels one die, so well-armoured foes take fewer of them."/>
                            <ListBox ItemsSource="{Binding Items}" HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource RefHeader}"/>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ListBox.GroupStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Id}" Foreground="#999" VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Top" TextWrapping="Wrap"/>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="#444"/>
                                                <TextBlock TextWrapping="Wrap" Foreground="#1565C0" Margin="0,2,0,0">
                                                    <Run Text="Damage:" FontWeight="SemiBold"/>
                                                    <Run Text="{Binding Damage}"/>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Damage}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- Paragraphs -->
                    <TabItem Header="Paragraphs">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Foreground="#555" TextWrapping="Wrap" Margin="2,2,2,6"
                                       Text="At scripted spots the game says &quot;read paragraph #N&quot; from the printed booklet. These are loaded from the game's own paragraphs.txt (auto-found from the .game folder, or load it manually) so nothing copyrighted is embedded in the trainer."/>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="2,0,2,6">
                                <Button Content="Load game folder…" Command="{Binding LoadParagraphsCommand}"/>
                                <TextBlock Text="{Binding ParagraphStatus}" Foreground="#777" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Paragraphs}" HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Label}" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Text}" TextWrapping="Wrap" Foreground="#444"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- Strategy -->
                    <TabItem Header="Strategy">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Strategy}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,4,4,10">
                                            <TextBlock Text="{Binding Title}" Style="{StaticResource RefHeader}"/>
                                            <TextBlock Text="{Binding Body}" TextWrapping="Wrap" Foreground="#444"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- ======================= MAPS ======================= -->
            <TabItem Header="Maps">
                <Grid Margin="6" DataContext="{Binding Maps}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Area / landmark reference -->
                    <GroupBox Grid.Column="0" Header="Areas">
                        <DockPanel>
                            <ComboBox DockPanel.Dock="Top" ItemsSource="{Binding Areas}"
                                      SelectedItem="{Binding SelectedArea}" DisplayMemberPath="Name" Margin="2"/>
                            <TextBlock DockPanel.Dock="Top" Text="{Binding SelectedArea.Notes}" TextWrapping="Wrap"
                                       Foreground="#555" Margin="4,2,4,6"/>
                            <ListBox ItemsSource="{Binding Landmarks}"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Notes}" TextWrapping="Wrap" Foreground="#666"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </GroupBox>

                    <!-- Live position (read-only) -->
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="6,0,0,0">
                        <StackPanel>
                            <GroupBox Header="Live position">
                                <StackPanel Margin="4">
                                    <TextBlock TextWrapping="Wrap" Foreground="#555"
                                               Text="Attach on the Party tab and the party's X/Y are read straight from the party-state header — no move-search needed. (The game doesn't keep a reliable current-map name, so use the Areas list on the left as a manual reference.) The green dot below marks the live position. Teleport isn't offered: the game never reads this position back, so writing it can't move the party — see the README."/>
                                    <TextBlock Text="{Binding LivePosition}" FontWeight="Bold" FontSize="13" Margin="0,6,0,0"/>
                                    <TextBlock Text="{Binding Status}" Foreground="#777" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Map (64 × 64 grid, origin bottom-left)" Margin="0,8,0,0">
                                <StackPanel Margin="4">
                                    <TextBlock TextWrapping="Wrap" Foreground="#555"
                                               Text="X runs across, Y up. Interiors are smaller than the 64×64 desert overworld. The green dot is the party's live position on the current map."/>
                                    <ScrollViewer MaxHeight="440" Margin="0,6,0,0"
                                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                        <Border BorderBrush="#CCC" BorderThickness="1" Background="#FBFBF5"
                                                HorizontalAlignment="Left" VerticalAlignment="Top" ClipToBounds="True"
                                                Width="{Binding GridWidth, Converter={StaticResource MapScale}}"
                                                Height="{Binding GridHeight, Converter={StaticResource MapScale}}">
                                            <Grid>
                                                <Rectangle>
                                                    <Rectangle.Fill>
                                                        <DrawingBrush TileMode="Tile" Viewport="0,0,10,10" ViewportUnits="Absolute">
                                                            <DrawingBrush.Drawing>
                                                                <GeometryDrawing Geometry="M0,0 L10,0 10,10 0,10 Z">
                                                                    <GeometryDrawing.Pen>
                                                                        <Pen Brush="#E4E4D8" Thickness="1"/>
                                                                    </GeometryDrawing.Pen>
                                                                </GeometryDrawing>
                                                            </DrawingBrush.Drawing>
                                                        </DrawingBrush>
                                                    </Rectangle.Fill>
                                                </Rectangle>

                                                <Canvas>
                                                    <Grid Width="10" Height="10" ToolTip="Your live position"
                                                          Visibility="{Binding HasParty, Converter={StaticResource BoolToVis}}"
                                                          Canvas.Left="{Binding LiveX, Converter={StaticResource MapScale}}">
                                                        <Canvas.Top>
                                                            <MultiBinding Converter="{StaticResource MapFlipY}">
                                                                <Binding Path="LiveY"/>
                                                                <Binding Path="GridHeight"/>
                                                            </MultiBinding>
                                                        </Canvas.Top>
                                                        <Ellipse Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                 Fill="#27AE60" Stroke="White" StrokeThickness="2"/>
                                                    </Grid>
                                                </Canvas>
                                            </Grid>
                                        </Border>
                                    </ScrollViewer>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ======================= CREATE (auto re-roll on the Ranger Center create screen) ======================= -->
            <TabItem Header="🎲 Create" DataContext="{Binding Roller}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <StackPanel Margin="6" MaxWidth="620" HorizontalAlignment="Left">
                        <TextBlock Text="Roll a ranger" Style="{StaticResource RefHeader}"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,8"
                                   Text="Automates the Ranger Center 'Create a character' re-roll: it taps the spacebar for you and reads each fresh roll straight from the game's memory, stopping when your target is hit. The freshly-rolled stats aren't a saved ranger yet, so the trainer first has to find them — type the numbers currently on the create screen, click Lock onto roll, then set a target and Roll. Attach to the game and open the create screen first."/>

                        <!-- 1 · capture the on-screen roll to locate it in memory -->
                        <GroupBox Header="1 · Capture the current roll" Margin="0,4,0,0">
                            <StackPanel Margin="4">
                                <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,6"
                                           Text="Enter the values exactly as they show on the create screen. 'Live' fills in once locked, and updates on every roll. MAXCON and SKP are optional but let the trainer confirm the record and re-roll for hit points too (SKP always equals IQ on a fresh roll)."/>
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Stat" Foreground="#777"/>
                                    <TextBlock Grid.Column="1" Text="On screen" Foreground="#777"/>
                                    <TextBlock Grid.Column="2" Text="Live" Foreground="#777"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Stats}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"
                                                           ToolTip="{Binding Description}"/>
                                                <TextBox Grid.Column="1" Width="60" HorizontalAlignment="Left"
                                                         Text="{Binding CapturedText, UpdateSourceTrigger=LostFocus}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding LiveText}" VerticalAlignment="Center"
                                                           FontFamily="Consolas" Foreground="#1565C0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Total of the seven attributes (excludes SKP and MAXCON). -->
                                <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,2"/>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Total" FontWeight="SemiBold" VerticalAlignment="Center"
                                               ToolTip="Sum of the seven attributes (STR, IQ, LCK, SPD, AGL, DEX, CHR); excludes SKP and MAXCON."/>
                                    <TextBlock Grid.Column="1" Text="{Binding CapturedTotalText}" VerticalAlignment="Center" Foreground="#555"/>
                                    <TextBlock Grid.Column="2" Text="{Binding LiveTotalText}" VerticalAlignment="Center"
                                               FontFamily="Consolas" FontWeight="SemiBold" Foreground="#1565C0"/>
                                </Grid>
                                <!-- SKP then MAXCON, matching the order the game shows them on the create screen. -->
                                <!-- SKP (captured only, to confirm the record — never a target) -->
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="SKP" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Width="60" HorizontalAlignment="Left"
                                             Text="{Binding CapturedSkpText, UpdateSourceTrigger=LostFocus}"/>
                                    <TextBlock Grid.Column="2" Text="(= IQ)" VerticalAlignment="Center" Foreground="#999"/>
                                </Grid>
                                <!-- MAXCON (own row: a u16, tracked only when the record shape is confirmed) -->
                                <Grid Margin="0,1" DataContext="{Binding MaxCon}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"
                                               ToolTip="{Binding Description}"/>
                                    <TextBox Grid.Column="1" Width="60" HorizontalAlignment="Left"
                                             Text="{Binding CapturedText, UpdateSourceTrigger=LostFocus}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding LiveText}" VerticalAlignment="Center"
                                               FontFamily="Consolas" Foreground="#1565C0"/>
                                </Grid>

                                <WrapPanel Margin="0,8,0,0">
                                    <Button Content="🎯 Lock onto roll" Command="{Binding LockCommand}"/>
                                    <Button Content="↻ Read current roll" Command="{Binding ReadOnceCommand}"/>
                                    <Button Content="✕ Reset lock" Command="{Binding ResetLockCommand}"/>
                                </WrapPanel>
                                <TextBlock Text="{Binding LockInfo}" Foreground="#555" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- 2 · target -->
                        <GroupBox Header="2 · Set your target" Margin="0,8,0,0">
                            <StackPanel Margin="4">
                                <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,6"
                                           Text="Set a minimum for each stat you care about. The roller stops once every stat is at or above its minimum. Leave a stat blank to ignore it."/>
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Stat" Foreground="#777"/>
                                    <TextBlock Grid.Column="1" Text="Minimum (≥)" Foreground="#777"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Stats}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"
                                                           ToolTip="{Binding Description}"/>
                                                <TextBox Grid.Column="1" Width="60" HorizontalAlignment="Left"
                                                         Text="{Binding MinimumText, UpdateSourceTrigger=PropertyChanged}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Optional target on the attribute total (sum of the seven attributes). -->
                                <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,2"/>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Total" FontWeight="SemiBold" VerticalAlignment="Center"
                                               ToolTip="Minimum for the sum of the seven attributes (STR, IQ, LCK, SPD, AGL, DEX, CHR); excludes SKP and MAXCON. A fair roll averages ~73–74."/>
                                    <TextBox Grid.Column="1" Width="60" HorizontalAlignment="Left"
                                             Text="{Binding TotalMinimumText, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                                <Grid Margin="0,1" DataContext="{Binding MaxCon}" IsEnabled="{Binding DataContext.MaxConAvailable, RelativeSource={RelativeSource AncestorType=TabItem}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"
                                               ToolTip="{Binding Description}"/>
                                    <TextBox Grid.Column="1" Width="60" HorizontalAlignment="Left"
                                             Text="{Binding MinimumText, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                                <TextBlock Text="{Binding MaxConNote}" Foreground="#999" TextWrapping="Wrap" FontSize="11" Margin="0,2,0,0"/>
                                <Button Content="🗑 Clear all targets" Command="{Binding ClearMinimumsCommand}"
                                        HorizontalAlignment="Left" Margin="0,6,0,0"
                                        ToolTip="Reset every minimum back to blank (no requirement)."/>
                                <TextBlock Text="{Binding CriteriaText}" Foreground="#1565C0" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding OddsText}" Foreground="#555" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- 3 · roll -->
                        <GroupBox Header="3 · Roll" Margin="0,8,0,0">
                            <StackPanel Margin="4">
                                <WrapPanel>
                                    <Button Content="🎲 Roll until target met" Command="{Binding StartCommand}"/>
                                    <Button Content="⏹ Stop" Command="{Binding StopCommand}"/>
                                </WrapPanel>
                                <TextBlock Text="{Binding AttemptsText}" Foreground="#555" Margin="0,6,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="Best so far: " Foreground="#555"/>
                                    <TextBlock Text="{Binding BestText}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ResultText}" TextWrapping="Wrap" Foreground="#1565C0" Margin="0,6,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- 4 · statistics -->
                        <GroupBox Header="4 · Statistics" Margin="0,8,0,0">
                            <StackPanel Margin="4">
                                <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,4"
                                           Text="Tallies every fresh roll read this session — Wasteland's create roll uses its own distribution, so these are plain averages and ranges, not a fairness judgement."/>
                                <TextBlock Text="{Binding SamplesText}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Stat" Foreground="#777"/>
                                    <TextBlock Grid.Column="1" Text="Average (min–max)" Foreground="#777"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Stats}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding AvgText}" VerticalAlignment="Center"
                                                           FontFamily="Consolas" Foreground="#1565C0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Attribute total (the seven attributes; excludes SKP and MAXCON). -->
                                <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,2"/>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Total" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TotalAvgText}" VerticalAlignment="Center"
                                               FontFamily="Consolas" FontWeight="SemiBold" Foreground="#1565C0"/>
                                </Grid>
                                <Grid Margin="0,1" DataContext="{Binding MaxCon}"
                                      Visibility="{Binding DataContext.MaxConAvailable, RelativeSource={RelativeSource AncestorType=TabItem}, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding AvgText}" VerticalAlignment="Center"
                                               FontFamily="Consolas" Foreground="#1565C0"/>
                                </Grid>
                                <Button Content="🗑 Clear statistics" Command="{Binding ClearStatsCommand}"
                                        HorizontalAlignment="Left" Margin="0,6,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <Expander Header="Advanced timing" Margin="0,8,0,0" Foreground="#555">
                            <WrapPanel Margin="0,6,0,0">
                                <StackPanel Margin="0,0,16,6">
                                    <Label Content="Max rolls"/>
                                    <TextBox Width="90" Text="{Binding MaxAttempts, UpdateSourceTrigger=LostFocus}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,16,6">
                                    <Label Content="Settle after space (ms)"/>
                                    <TextBox Width="90" Text="{Binding SettleDelayMs, UpdateSourceTrigger=LostFocus}"
                                             ToolTip="Pause after each re-roll so the game updates memory before the trainer reads it. Raise this if rolls read stale."/>
                                </StackPanel>
                                <StackPanel Margin="0,0,16,6">
                                    <Label Content="Focus pause (ms)"/>
                                    <TextBox Width="90" Text="{Binding FocusDelayMs, UpdateSourceTrigger=LostFocus}"/>
                                </StackPanel>
                            </WrapPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ======================= SAVE EDITOR ======================= -->
            <TabItem Header="Save Editor" DataContext="{Binding SaveEditor}">
                <DockPanel Margin="6">
                    <!-- Open / Save toolbar -->
                    <Border DockPanel.Dock="Top" Background="#F6F6F6" Padding="6" Margin="0,0,0,6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Open GAME1/GAME2…" Command="{Binding OpenCommand}"/>
                                <Button Content="Save" Command="{Binding SaveCommand}"/>
                                <TextBlock Text="{Binding LoadedPath}" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="#555" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Foreground="#1565C0" Margin="2,6,2,0"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#777" FontSize="11" Margin="2,4,2,0"
                                       Text="Edits an offline Wasteland save. This is the only way to teleport: the running game never reads the live position back (see the Maps tab), but it DOES read these fields on load. Saving bumps the save serial so the game loads this file next, and keeps a one-time .bak of the original."/>
                        </StackPanel>
                    </Border>

                    <Grid IsEnabled="{Binding IsLoaded}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <!-- Position & time / teleport -->
                            <GroupBox Header="Position &amp; time">
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding HeaderSummary}" Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Map" Style="{StaticResource FieldLabel}" MinWidth="30"/>
                                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding MapId, UpdateSourceTrigger=LostFocus}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="X" Style="{StaticResource FieldLabel}" MinWidth="30"/>
                                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding PartyX, UpdateSourceTrigger=LostFocus}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Y" Style="{StaticResource FieldLabel}" MinWidth="30"/>
                                        <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding PartyY, UpdateSourceTrigger=LostFocus}"/>
                                    </Grid>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Hour" Style="{StaticResource FieldLabel}" MinWidth="30"/>
                                        <TextBox   Grid.Column="1" Text="{Binding Hour, UpdateSourceTrigger=LostFocus}"/>
                                        <TextBlock Grid.Column="2" Text="Min" Style="{StaticResource FieldLabel}" MinWidth="30"/>
                                        <TextBox   Grid.Column="3" Text="{Binding Minute, UpdateSourceTrigger=LostFocus}"/>
                                    </Grid>

                                    <TextBlock Text="Jump to" Style="{StaticResource RefHeader}"/>
                                    <ComboBox x:Name="TeleportCombo" ItemsSource="{Binding TeleportTargets}"
                                              DisplayMemberPath="Name" SelectedIndex="0"
                                              ToolTip="Confirmed destinations plus spots you've saved from a loaded game. For anywhere else, type the map id and X/Y above (0..63)."/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Button Content="Teleport party here"
                                                Command="{Binding ApplyTeleportCommand}"
                                                CommandParameter="{Binding SelectedItem, ElementName=TeleportCombo}"
                                                HorizontalAlignment="Left" Margin="2,0"/>
                                        <Button Content="Remove"
                                                Command="{Binding RemoveBookmarkCommand}"
                                                CommandParameter="{Binding SelectedItem, ElementName=TeleportCombo}"
                                                ToolTip="Removes the selected saved spot (built-in destinations can't be removed)."
                                                HorizontalAlignment="Left" Margin="2,0"/>
                                    </StackPanel>

                                    <TextBlock Text="Save this spot" Style="{StaticResource RefHeader}"/>
                                    <TextBlock Text="Load a game standing where you want a bookmark, then name and save it — the map and X/Y are captured exactly as the game reads them."
                                               Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Width="150" Text="{Binding BookmarkName, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Name for the current map/X/Y as a new Jump-to destination."/>
                                        <Button Content="Save current spot"
                                                Command="{Binding AddBookmarkCommand}"
                                                HorizontalAlignment="Left" Margin="4,0,2,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Rangers" Margin="0,6,0,0">
                                <ListBox ItemsSource="{Binding Characters}" SelectedItem="{Binding SelectedCharacter}"
                                         DisplayMemberPath="ListLabel" Height="220"/>
                            </GroupBox>
                        </StackPanel>

                        <!-- Selected ranger editor (reuses CharacterViewModel) -->
                        <GroupBox Grid.Column="1" Header="Ranger" Margin="6,0,0,0"
                                  DataContext="{Binding SelectedCharacter}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="6">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding Summary}" Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="130"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource FieldLabel}"/>
                                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Name}" MaxLength="13"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Gender" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox  Grid.Row="0" Grid.Column="3" Margin="2" ItemsSource="{Binding GenderOptions}"
                                                   SelectedIndex="{Binding GenderIndex}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Level" Style="{StaticResource FieldLabel}"/>
                                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Level}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Nationality" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox  Grid.Row="1" Grid.Column="3" Margin="2" ItemsSource="{Binding NationalityOptions}"
                                                   SelectedIndex="{Binding NationalityIndex}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Experience" Style="{StaticResource FieldLabel}"/>
                                        <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding Experience}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Money ($)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox   Grid.Row="2" Grid.Column="3" Text="{Binding Money}"/>
                                    </Grid>

                                    <GroupBox Header="Constitution &amp; progression" Margin="0,8,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="CON" Style="{StaticResource FieldLabel}"/>
                                            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Con}"/>
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="/ Max" Style="{StaticResource FieldLabel}"/>
                                            <TextBox   Grid.Row="0" Grid.Column="3" Text="{Binding MaxCon}"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Skill pts" Style="{StaticResource FieldLabel}"/>
                                            <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding SkillPoints}"/>
                                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Armor Cls" Style="{StaticResource FieldLabel}"/>
                                            <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding ArmorClass}"/>
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox Header="Attributes" Margin="0,8,0,0">
                                        <ItemsControl ItemsSource="{Binding Attributes}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="4">
                                                        <TextBlock Text="{Binding Name}" Width="40" VerticalAlignment="Center"
                                                                   ToolTip="{Binding Description}"/>
                                                        <TextBox Width="60" Text="{Binding Value}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </GroupBox>

                                    <GroupBox Header="Skills" Margin="0,8,0,0">
                                        <ItemsControl ItemsSource="{Binding Skills}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="4,2" Width="215">
                                                        <TextBlock Text="{Binding Name}" Width="135" VerticalAlignment="Center"
                                                                   ToolTip="{Binding Description}"/>
                                                        <TextBox Width="55" Text="{Binding Level}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </GroupBox>

                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Content="Full Heal" Click="FullHeal_Click"/>
                                        <Button Content="Max Attributes" Click="MaxAttributes_Click"/>
                                        <Button Content="Max Skills" Click="MaxSkills_Click"/>
                                        <Button Content="Max Money" Click="MaxMoney_Click"/>
                                        <Button Content="Max Everything" Click="MaxEverything_Click"/>
                                    </WrapPanel>

                                    <GroupBox Header="Carried Items" Margin="0,8,0,0">
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="2,3">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="28"/>
                                                                <ColumnDefinition Width="260"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="55"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding SlotLabel}" VerticalAlignment="Center" Foreground="#888"/>
                                                            <ComboBox  Grid.Column="1" Margin="2" IsEditable="True" StaysOpenOnEdit="True"
                                                                       IsTextSearchEnabled="False" ItemsSource="{Binding Options}"
                                                                       DisplayMemberPath="Label"
                                                                       Text="{Binding Selection, UpdateSourceTrigger=LostFocus}"
                                                                       SelectionChanged="ItemSelected"
                                                                       ToolTip="Pick an item, or type its name or a raw item id (0 = empty)"/>
                                                            <TextBlock Grid.Column="2" Text="Qty" Style="{StaticResource FieldLabel}" MinWidth="0"/>
                                                            <TextBox   Grid.Column="3" Text="{Binding Quantity}"
                                                                       ToolTip="Ammunition / charge / quantity byte"/>
                                                            <TextBlock Grid.Column="4" Text="{Binding Name}" Foreground="#555"
                                                                       VerticalAlignment="Center" Margin="8,0" TextTrimming="CharacterEllipsis"/>
                                                            <Button    Grid.Column="5" Content="Clear" Click="ClearItem_Click"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </GroupBox>
                                </StackPanel>
                            </ScrollViewer>
                        </GroupBox>
                    </Grid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
